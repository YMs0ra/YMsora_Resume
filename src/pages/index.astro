---
import Layout from '../layouts/Layout.astro';
import ResumeContent, { frontmatter } from '../content/resume.md';

const tags = Array.isArray(frontmatter.tags) ? frontmatter.tags : [];
const intro = Array.isArray(frontmatter.intro) ? frontmatter.intro : [];
const stats = Array.isArray(frontmatter.stats) ? frontmatter.stats : [];
const highlights = Array.isArray(frontmatter.highlights) ? frontmatter.highlights : [];
const competitions = Array.isArray(frontmatter.competitions) ? frontmatter.competitions : [];
const experiencePoints = Array.isArray(frontmatter.experience_points) ? frontmatter.experience_points : [];
const skillGroups = Array.isArray(frontmatter.skill_groups) ? frontmatter.skill_groups : [];
const projects = Array.isArray(frontmatter.projects) ? frontmatter.projects : [];
const community = Array.isArray(frontmatter.community) ? frontmatter.community : [];
const contacts = Array.isArray(frontmatter.contacts) ? frontmatter.contacts : [];
---

<Layout title={`${frontmatter.name} | Security Resume`} description={frontmatter.headline}>
  <main class="resume-page">
    <section class="hero-card">
      <div class="hero-copy">
        <p class="eyebrow">Security Portfolio / Resume</p>
        <h1>{frontmatter.name}</h1>
        <p class="role">{frontmatter.role}</p>
        <p class="headline">{frontmatter.headline}</p>

        <div class="meta-row">
          <span>{frontmatter.location}</span>
          <span class="dot"></span>
          <a href={`mailto:${frontmatter.email}`}>{frontmatter.email}</a>
          <span class="dot"></span>
          <a href={`https://${frontmatter.github}`}>{frontmatter.github}</a>
        </div>

        <div class="tag-list">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>

        <div class="quick-points">
          {intro.map((item) => <p>{item}</p>)}
        </div>

        <div class="hero-actions">
          <a class="primary-btn" href={`mailto:${frontmatter.email}`}>邮件联系 / 合作交流</a>
          <a class="secondary-btn" href={`https://${frontmatter.blog}`}>查看博客与复盘</a>
        </div>
      </div>

      <div class="avatar-panel">
        <div class="avatar-ring">
          <img src={frontmatter.avatar ?? '/avatar-placeholder.svg'} alt={`${frontmatter.name} avatar`} />
        </div>
        <div class="floating-card card-one">CTF / Web</div>
        <div class="floating-card card-two">Research Mode</div>
      </div>
    </section>

    <section class="stats-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Impact Snapshot</p>
        <h2>核心成果</h2>
      </div>
      <div class="stats-grid">
        {stats.map((item) => (
          <article class="stat-card">
            <span class="stat-value">{item.value}</span>
            <h3>{item.label}</h3>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="highlights-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Security Highlights</p>
        <h2>代表性成果</h2>
      </div>
      <div class="highlight-grid">
        {highlights.map((item) => (
          <article class="highlight-card">
            <div class="highlight-topline"></div>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <div class="mini-tags">
              {(Array.isArray(item.tags) ? item.tags : []).map((tag) => <span>{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="competition-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Competition Matrix</p>
        <h2>竞赛成绩</h2>
      </div>
      <div class="competition-grid">
        {competitions.map((item, index) => (
          <article class:list={["competition-card", index < 2 && "competition-card--featured"]}>
            <p class="competition-type">{item.type}</p>
            <h3>{item.name}</h3>
            <strong>{item.result}</strong>
          </article>
        ))}
      </div>
      <div class="experience-strip">
        {experiencePoints.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="skills-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Skill Matrix</p>
        <h2>技术栈与能力</h2>
      </div>
      <div class="skills-grid">
        {skillGroups.map((group) => (
          <article class="skill-panel">
            <h3>{group.title}</h3>
            <div class="skill-items">
              {(Array.isArray(group.items) ? group.items : []).map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="project-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Projects & Influence</p>
        <h2>项目与开源输出</h2>
      </div>
      <div class="project-layout">
        <div class="project-grid">
          {projects.map((project) => (
            <article class="project-card">
              <p class="project-meta">{project.meta}</p>
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
              <ul>
                {(Array.isArray(project.bullets) ? project.bullets : []).map((bullet) => <li>{bullet}</li>)}
              </ul>
              <div class="mini-tags">
                {(Array.isArray(project.tags) ? project.tags : []).map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))}
        </div>

        <div class="community-panel">
          <h3>持续输出</h3>
          <div class="community-list">
            {community.map((item) => (
              <article>
                <h4>{item.title}</h4>
                <p>{item.summary}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="story-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Narrative</p>
        <h2>个人概述</h2>
      </div>
      <article class="story-card">
        <ResumeContent />
      </article>
    </section>

    <section class="contact-section panel-section">
      <div class="cta-card">
        <div>
          <p class="section-kicker">Contact & Collaboration</p>
          <h2>欢迎就 Web 安全研究、CTF 训练与漏洞分析进行交流合作</h2>
          <p class="cta-copy">如果你想聊安全研究、项目合作、CTF 训练或漏洞分析，可以直接通过下方方式联系我。</p>
        </div>

        <div class="contact-grid">
          {contacts.map((item) => (
            <article class="contact-chip">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .resume-page {
    display: grid;
    gap: 24px;
  }

  .panel-section,
  .hero-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 26px;
    background:
      linear-gradient(180deg, rgba(18, 22, 42, 0.98), rgba(9, 13, 28, 0.96));
    box-shadow: var(--shadow);
  }

  .panel-section::before,
  .hero-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(6, 182, 212, 0.06), transparent 18%, transparent 82%, rgba(124, 58, 237, 0.08)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 22%);
    pointer-events: none;
  }

  .panel-section::after,
  .hero-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 26px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    pointer-events: none;
  }

  .hero-card {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 380px);
    gap: 28px;
    min-height: 520px;
    padding: 34px;
    isolation: isolate;
  }

  .hero-copy,
  .section-head,
  .story-card,
  .cta-card,
  .project-layout,
  .stats-grid,
  .highlight-grid,
  .competition-grid,
  .experience-strip,
  .skills-grid {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .hero-copy {
    align-self: center;
  }

  .eyebrow,
  .section-kicker {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.8rem;
    border: 1px solid rgba(6, 182, 212, 0.18);
    border-radius: 999px;
    background: rgba(10, 14, 28, 0.8);
    color: #d8ddff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.73rem;
    margin: 0;
  }

  h1 {
    margin: 18px 0 10px;
    font-size: clamp(3rem, 8vw, 5.2rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    white-space: nowrap;
    text-shadow:
      0 0 10px rgba(6, 182, 212, 0.14),
      0 0 18px rgba(124, 58, 237, 0.12);
  }

  h2 {
    margin: 12px 0 0;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    letter-spacing: -0.03em;
  }

  h3,
  h4,
  p {
    margin-top: 0;
  }

  .role {
    margin: 0;
    font-size: clamp(1.06rem, 2vw, 1.35rem);
    color: #d8ddff;
  }

  .headline,
  .cta-copy {
    max-width: 46rem;
    margin: 18px 0 0;
    font-size: 1.02rem;
    line-height: 1.78;
    color: var(--muted);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: 22px;
    color: #c5cced;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent-2), var(--accent-3));
  }

  .tag-list,
  .mini-tags,
  .skill-items,
  .experience-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag,
  .mini-tags span,
  .experience-strip span {
    min-width: 0;
    max-width: 100%;
    padding: 0.62rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(10, 14, 28, 0.92);
    color: #f3f5ff;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .skill-items span {
    min-width: 0;
    max-width: 100%;
    padding: 0.62rem 0.9rem;
    border-radius: 12px;
    border: 1px solid rgba(6, 182, 212, 0.16);
    background: rgba(10, 14, 28, 0.96);
    color: #dfe8ff;
    font-size: 0.95rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .tag-list {
    margin-top: 28px;
  }

  .quick-points {
    display: grid;
    gap: 10px;
    margin-top: 26px;
  }

  .quick-points p {
    margin: 0;
    padding-left: 16px;
    border-left: 2px solid rgba(6, 182, 212, 0.28);
    color: #dbe2ff;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .primary-btn,
  .secondary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    padding: 0.92rem 1.2rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .primary-btn {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.86), rgba(6, 182, 212, 0.7));
    box-shadow: 0 10px 26px rgba(124, 58, 237, 0.22);
  }

  .secondary-btn {
    background: rgba(10, 14, 28, 0.92);
  }

  .primary-btn:hover,
  .secondary-btn:hover {
    transform: translateY(-2px);
  }

  .secondary-btn:hover {
    border-color: rgba(6, 182, 212, 0.28);
    box-shadow: 0 8px 18px rgba(6, 182, 212, 0.08);
  }

  .avatar-panel {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 400px;
  }

  .avatar-ring {
    position: relative;
    z-index: 1;
    width: min(100%, 320px);
    aspect-ratio: 1;
    padding: 10px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.75), rgba(6, 182, 212, 0.68), rgba(244, 114, 182, 0.72));
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.26);
  }

  .avatar-ring::after {
    content: "";
    position: absolute;
    inset: -8px;
    border-radius: 34px;
    border: 1px solid rgba(6, 182, 212, 0.14);
  }

  .avatar-ring img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 20px;
    background: #0d1020;
  }

  .floating-card {
    position: absolute;
    z-index: 2;
    padding: 0.7rem 0.9rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(10, 14, 28, 0.95);
    color: #eef2ff;
    font-size: 0.88rem;
  }

  .card-one {
    top: 54px;
    right: 10px;
  }

  .card-two {
    bottom: 54px;
    left: 18px;
  }

  .panel-section {
    padding: 28px;
  }

  .section-head {
    position: relative;
    margin-bottom: 20px;
    padding-bottom: 16px;
  }

  .section-head::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: min(180px, 38%);
    height: 1px;
    background: linear-gradient(90deg, rgba(6, 182, 212, 0.75), rgba(124, 58, 237, 0.45), transparent);
  }

  .stats-grid,
  .highlight-grid,
  .competition-grid,
  .skills-grid,
  .contact-grid {
    display: grid;
    gap: 16px;
  }

  .stats-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .highlight-grid,
  .competition-grid,
  .contact-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .skills-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-card,
  .highlight-card,
  .competition-card,
  .skill-panel,
  .project-card,
  .community-panel,
  .story-card,
  .contact-chip {
    position: relative;
    z-index: 1;
    min-width: 0;
    padding: 20px;
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(14, 18, 36, 0.98), rgba(8, 11, 24, 0.96));
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .stat-card {
    min-height: 170px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .stat-value {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    color: #f8faff;
    text-shadow: 0 0 12px rgba(6, 182, 212, 0.14);
  }

  .stat-card h3,
  .highlight-card h3,
  .competition-card h3,
  .skill-panel h3,
  .project-card h3,
  .community-panel h3 {
    margin: 12px 0 10px;
    font-size: 1.16rem;
  }

  .stat-card p,
  .highlight-card p,
  .competition-card p,
  .project-card p,
  .community-panel p,
  .contact-chip span,
  .story-card :global(p),
  .story-card :global(li) {
    color: #c6ceed;
    line-height: 1.78;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .highlight-topline {
    width: 48px;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent-2), var(--accent-3));
    margin-bottom: 14px;
  }

  .competition-card strong,
  .contact-chip strong {
    display: block;
    margin-top: 12px;
    font-size: 1.16rem;
    color: #f8fbff;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .competition-type,
  .project-meta {
    color: #9ab2f3;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .competition-card--featured {
    border-color: rgba(124, 58, 237, 0.18);
    background: linear-gradient(180deg, rgba(20, 16, 46, 0.96), rgba(12, 14, 34, 0.96));
  }

  .experience-strip {
    margin-top: 16px;
  }

  .project-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.8fr);
    gap: 16px;
    min-width: 0;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    min-width: 0;
  }

  .project-card ul {
    margin: 14px 0 0;
    padding-left: 18px;
    color: #c6ceed;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .community-list {
    display: grid;
    gap: 14px;
    margin-top: 16px;
  }

  .story-card :global(h1),
  .story-card :global(h2),
  .story-card :global(h3) {
    letter-spacing: -0.03em;
  }

  .story-card :global(h1) {
    margin-top: 0;
    font-size: 1.8rem;
  }

  .cta-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.95fr);
    gap: 18px;
  }

  .contact-chip {
    min-height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-chip span {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8fa6e8;
  }

  @media (max-width: 1100px) {
    .stats-grid,
    .highlight-grid,
    .competition-grid,
    .skills-grid,
    .contact-grid,
    .project-grid,
    .cta-card,
    .project-layout {
      grid-template-columns: 1fr 1fr;
    }

    .cta-card,
    .project-layout {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .hero-card {
      grid-template-columns: 1fr;
      padding: 24px;
    }

    .avatar-panel {
      min-height: 300px;
      order: -1;
    }

    .avatar-ring {
      width: min(100%, 260px);
    }

    .card-one {
      right: 16px;
      top: 18px;
    }

    .card-two {
      left: 16px;
      bottom: 18px;
    }
  }

  @media (max-width: 720px) {
    .panel-section {
      padding: 18px;
    }

    .stats-grid,
    .highlight-grid,
    .competition-grid,
    .skills-grid,
    .contact-grid,
    .project-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
    }
  }
</style>
