---
import Layout from '../layouts/Layout.astro';
import ResumeContent, { frontmatter } from '../content/resume.md';

const tags = Array.isArray(frontmatter.tags) ? frontmatter.tags : [];
const intro = Array.isArray(frontmatter.intro) ? frontmatter.intro : [];
const stats = Array.isArray(frontmatter.stats) ? frontmatter.stats : [];
const highlights = Array.isArray(frontmatter.highlights) ? frontmatter.highlights : [];
const competitions = Array.isArray(frontmatter.competitions) ? frontmatter.competitions : [];
const experiencePoints = Array.isArray(frontmatter.experience_points) ? frontmatter.experience_points : [];
const skillGroups = Array.isArray(frontmatter.skill_groups) ? frontmatter.skill_groups : [];
const projects = Array.isArray(frontmatter.projects) ? frontmatter.projects : [];
const community = Array.isArray(frontmatter.community) ? frontmatter.community : [];
const contacts = Array.isArray(frontmatter.contacts) ? frontmatter.contacts : [];
---

<Layout title={`${frontmatter.name} | Security Resume`} description={frontmatter.headline}>
  <main class="resume-page">
    <section class="hero-card" id="hero-card">
      <div class="hero-copy">
        <p class="eyebrow">Security Portfolio / Resume</p>
        <h1>{frontmatter.name}</h1>
        <p class="role">{frontmatter.role}</p>
        <p class="headline">{frontmatter.headline}</p>

        <div class="meta-row">
          <span>{frontmatter.location}</span>
          <span class="dot"></span>
          <a href={`mailto:${frontmatter.email}`}>{frontmatter.email}</a>
          <span class="dot"></span>
          <a href={`https://${frontmatter.github}`}>{frontmatter.github}</a>
        </div>

        <div class="tag-list">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>

        <div class="quick-points">
          {intro.map((item) => <p>{item}</p>)}
        </div>

        <div class="hero-actions">
          <a class="primary-btn" href={`mailto:${frontmatter.email}`}>邮件联系 / 合作交流</a>
          <a class="secondary-btn" href={`https://${frontmatter.blog}`}>查看博客与复盘</a>
        </div>
      </div>

      <div class="avatar-panel">
        <div class="avatar-ring">
          <img src={frontmatter.avatar ?? '/avatar-placeholder.svg'} alt={`${frontmatter.name} avatar`} />
        </div>
        <div class="avatar-glow"></div>
        <div class="floating-card card-one">CTF / Web</div>
        <div class="floating-card card-two">Research Mode</div>
      </div>
    </section>

    <section class="stats-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Impact Snapshot</p>
        <h2>核心成果</h2>
      </div>
      <div class="stats-grid">
        {stats.map((item) => (
          <article class="stat-card">
            <span class="stat-value">{item.value}</span>
            <h3>{item.label}</h3>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="highlights-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Security Highlights</p>
        <h2>代表性成果</h2>
      </div>
      <div class="highlight-grid">
        {highlights.map((item) => (
          <article class="highlight-card">
            <div class="highlight-topline"></div>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <div class="mini-tags">
              {(Array.isArray(item.tags) ? item.tags : []).map((tag) => <span>{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="competition-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Competition Matrix</p>
        <h2>竞赛成绩</h2>
      </div>
      <div class="competition-grid">
        {competitions.map((item, index) => (
          <article class:list={["competition-card", index < 2 && "competition-card--featured"]}>
            <p class="competition-type">{item.type}</p>
            <h3>{item.name}</h3>
            <strong>{item.result}</strong>
          </article>
        ))}
      </div>
      <div class="experience-strip">
        {experiencePoints.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="skills-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Skill Matrix</p>
        <h2>技术栈与能力</h2>
      </div>
      <div class="skills-grid">
        {skillGroups.map((group) => (
          <article class="skill-panel">
            <h3>{group.title}</h3>
            <div class="skill-items">
              {(Array.isArray(group.items) ? group.items : []).map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="project-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Projects & Influence</p>
        <h2>项目与开源输出</h2>
      </div>
      <div class="project-layout">
        <div class="project-grid">
          {projects.map((project) => (
            <article class="project-card">
              <p class="project-meta">{project.meta}</p>
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
              <ul>
                {(Array.isArray(project.bullets) ? project.bullets : []).map((bullet) => <li>{bullet}</li>)}
              </ul>
              <div class="mini-tags">
                {(Array.isArray(project.tags) ? project.tags : []).map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))}
        </div>

        <div class="community-panel">
          <h3>持续输出</h3>
          <div class="community-list">
            {community.map((item) => (
              <article>
                <h4>{item.title}</h4>
                <p>{item.summary}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="story-section panel-section">
      <div class="section-head">
        <p class="section-kicker">Narrative</p>
        <h2>个人概述</h2>
      </div>
      <article class="story-card">
        <ResumeContent />
      </article>
    </section>

    <section class="contact-section panel-section">
      <div class="cta-card">
        <div>
          <p class="section-kicker">Contact & Collaboration</p>
          <h2>欢迎就 Web 安全研究、CTF 训练与漏洞分析进行交流合作</h2>
          <p class="cta-copy">如果你想聊安全研究、项目合作、CTF 训练或漏洞分析，可以直接通过下方方式联系我。</p>
        </div>

        <div class="contact-grid">
          {contacts.map((item) => (
            <article class="contact-chip">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .resume-page {
    display: grid;
    gap: 30px;
  }

  .panel-section,
  .hero-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 32px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      var(--card);
    backdrop-filter: blur(22px);
    box-shadow:
      var(--shadow),
      0 0 60px rgba(124, 58, 237, 0.12),
      0 0 100px rgba(6, 182, 212, 0.08);
  }

  .panel-section::before,
  .hero-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(124, 58, 237, 0.12), transparent 34%, rgba(6, 182, 212, 0.12) 72%, rgba(244, 114, 182, 0.14));
    pointer-events: none;
  }

  .panel-section::after,
  .hero-card::after {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: 32px;
    background: linear-gradient(120deg, rgba(124, 58, 237, 1), rgba(6, 182, 212, 0.9), rgba(244, 114, 182, 0.94), rgba(124, 58, 237, 1));
    background-size: 260% 260%;
    animation: borderFlow 6s linear infinite;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.85;
    pointer-events: none;
  }

  .hero-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 400px);
    gap: 28px;
    min-height: 560px;
    padding: 36px;
    isolation: isolate;
    transform-style: preserve-3d;
    transition: transform 220ms ease, box-shadow 220ms ease;
    will-change: transform;
  }

  .hero-card.is-tilting {
    box-shadow:
      0 36px 90px rgba(0, 0, 0, 0.52),
      0 0 55px rgba(124, 58, 237, 0.18);
  }

  .hero-copy,
  .section-head,
  .story-card,
  .cta-card,
  .project-layout,
  .stats-grid,
  .highlight-grid,
  .competition-grid,
  .experience-strip,
  .skills-grid {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .hero-copy {
    align-self: center;
    transform: translateZ(18px);
  }

  .eyebrow,
  .section-kicker {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: #d8ddff;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.75rem;
    margin: 0;
  }

  h1 {
    margin: 18px 0 10px;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    white-space: nowrap;
    text-shadow:
      0 0 12px rgba(124, 58, 237, 0.45),
      0 0 26px rgba(6, 182, 212, 0.22),
      0 0 42px rgba(244, 114, 182, 0.16);
    animation: neonFlicker 6.4s linear infinite;
  }

  h2 {
    margin: 14px 0 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    letter-spacing: -0.03em;
  }

  h3,
  h4,
  p {
    margin-top: 0;
  }

  .role {
    margin: 0;
    font-size: clamp(1.1rem, 2vw, 1.45rem);
    color: #d8ddff;
  }

  .headline,
  .cta-copy {
    max-width: 46rem;
    margin: 18px 0 0;
    font-size: 1.06rem;
    line-height: 1.85;
    color: var(--muted);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: 22px;
    color: #c5cced;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent-2), var(--accent-3));
    box-shadow: 0 0 16px rgba(6, 182, 212, 0.8);
  }

  .tag-list,
  .mini-tags,
  .skill-items,
  .experience-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tag,
  .mini-tags span,
  .skill-items span,
  .experience-strip span {
    position: relative;
    min-width: 0;
    max-width: 100%;
    padding: 0.72rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(7, 10, 24, 0.46);
    color: #f3f5ff;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    overflow: hidden;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .tag-list {
    margin-top: 28px;
  }

  .tag::after,
  .mini-tags span::after,
  .skill-items span::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.2) 45%, transparent 72%);
    transform: translateX(-135%);
    animation: tagSweep 7s ease-in-out infinite;
  }

  .quick-points {
    display: grid;
    gap: 10px;
    margin-top: 26px;
  }

  .quick-points p {
    margin: 0;
    padding-left: 16px;
    border-left: 2px solid rgba(6, 182, 212, 0.34);
    color: #dbe2ff;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .primary-btn,
  .secondary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 160px;
    padding: 0.95rem 1.25rem;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease, border-color 160ms ease;
  }

  .primary-btn {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.92), rgba(6, 182, 212, 0.82));
    box-shadow: 0 18px 36px rgba(124, 58, 237, 0.28);
  }

  .secondary-btn {
    background: rgba(255, 255, 255, 0.06);
  }

  .primary-btn:hover,
  .secondary-btn:hover {
    transform: translateY(-2px);
  }

  .secondary-btn:hover {
    border-color: rgba(6, 182, 212, 0.34);
    box-shadow: 0 12px 28px rgba(6, 182, 212, 0.12);
  }

  .avatar-panel {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 440px;
    transform: translateZ(26px);
  }

  .avatar-ring {
    position: relative;
    z-index: 1;
    width: min(100%, 320px);
    aspect-ratio: 1;
    padding: 12px;
    border-radius: 36px;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.95), rgba(6, 182, 212, 0.9), rgba(244, 114, 182, 0.95));
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.12),
      0 24px 90px rgba(124, 58, 237, 0.35);
    transform: rotate(4deg);
    animation: avatarFloat 6.5s ease-in-out infinite;
  }

  .avatar-ring::after {
    content: "";
    position: absolute;
    inset: -10px;
    border-radius: 42px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    opacity: 0.6;
    animation: orbitGlow 10s linear infinite;
  }

  .avatar-ring img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 28px;
    background: linear-gradient(160deg, rgba(11, 13, 31, 0.9), rgba(20, 28, 56, 0.95));
  }

  .avatar-glow {
    position: absolute;
    width: 280px;
    height: 280px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.45), rgba(124, 58, 237, 0.12), transparent 68%);
    filter: blur(16px);
    animation: glowPulse 5.6s ease-in-out infinite;
  }

  .floating-card {
    position: absolute;
    z-index: 2;
    padding: 0.8rem 1rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(9, 13, 28, 0.72);
    backdrop-filter: blur(16px);
    color: #eef2ff;
    font-size: 0.92rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
  }

  .card-one {
    top: 54px;
    right: 6px;
    animation: floatCardA 7s ease-in-out infinite;
  }

  .card-two {
    bottom: 54px;
    left: 18px;
    animation: floatCardB 8.4s ease-in-out infinite;
  }

  .panel-section {
    padding: 30px;
  }

  .section-head {
    position: relative;
    margin-bottom: 22px;
    padding-bottom: 18px;
  }

  .section-head::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: min(180px, 38%);
    height: 1px;
    background: linear-gradient(90deg, rgba(6, 182, 212, 0.8), rgba(124, 58, 237, 0.55), transparent);
    box-shadow: 0 0 14px rgba(6, 182, 212, 0.24);
  }

  .stats-grid,
  .highlight-grid,
  .competition-grid,
  .skills-grid,
  .contact-grid {
    display: grid;
    gap: 18px;
  }

  .stats-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .highlight-grid,
  .competition-grid,
  .contact-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .skills-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stat-card,
  .highlight-card,
  .competition-card,
  .skill-panel,
  .project-card,
  .community-panel,
  .story-card,
  .contact-chip {
    position: relative;
    z-index: 1;
    min-width: 0;
    padding: 22px;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(12, 16, 38, 0.86), rgba(8, 12, 28, 0.78));
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 14px 36px rgba(0, 0, 0, 0.24);
  }

  .stat-card {
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .stat-value {
    font-size: clamp(2.3rem, 4vw, 3.4rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    color: #f8faff;
    text-shadow:
      0 0 18px rgba(6, 182, 212, 0.24),
      0 0 30px rgba(124, 58, 237, 0.14);
  }

  .stat-card h3,
  .highlight-card h3,
  .competition-card h3,
  .skill-panel h3,
  .project-card h3,
  .community-panel h3 {
    margin: 12px 0 10px;
    font-size: 1.2rem;
  }

  .stat-card p,
  .highlight-card p,
  .competition-card p,
  .project-card p,
  .community-panel p,
  .contact-chip span,
  .story-card :global(p),
  .story-card :global(li) {
    color: #c6ceed;
    line-height: 1.8;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .highlight-card,
  .competition-card,
  .project-card,
  .community-panel,
  .story-card {
    backdrop-filter: blur(14px);
  }

  .highlight-topline {
    width: 54px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--accent-2), var(--accent-3));
    box-shadow: 0 0 16px rgba(6, 182, 212, 0.45);
    margin-bottom: 16px;
  }

  .competition-card strong,
  .contact-chip strong {
    display: block;
    margin-top: 12px;
    font-size: 1.2rem;
    color: #f8fbff;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .competition-type,
  .project-meta {
    color: #9ab2f3;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
  }

  .competition-card--featured {
    background: linear-gradient(180deg, rgba(20, 16, 46, 0.92), rgba(12, 14, 34, 0.82));
    box-shadow:
      0 0 0 1px rgba(124, 58, 237, 0.24),
      0 0 40px rgba(124, 58, 237, 0.18),
      inset 0 0 24px rgba(6, 182, 212, 0.05);
  }

  .experience-strip {
    margin-top: 18px;
  }

  .project-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.8fr);
    gap: 18px;
    min-width: 0;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    min-width: 0;
  }

  .project-card ul {
    margin: 16px 0 0;
    padding-left: 18px;
    color: #c6ceed;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .community-list {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }

  .story-card :global(h1),
  .story-card :global(h2),
  .story-card :global(h3) {
    letter-spacing: -0.03em;
  }

  .story-card :global(h1) {
    margin-top: 0;
    font-size: 1.9rem;
  }

  .cta-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.95fr);
    gap: 22px;
  }

  .contact-chip {
    min-height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-chip span {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8fa6e8;
  }

  @keyframes borderFlow {
    0% {
      background-position: 0% 50%;
      filter: saturate(1);
    }
    50% {
      background-position: 100% 50%;
      filter: saturate(1.2);
    }
    100% {
      background-position: 200% 50%;
      filter: saturate(1);
    }
  }

  @keyframes neonFlicker {
    0%,
    18%,
    22%,
    53%,
    57%,
    100% {
      opacity: 1;
      text-shadow:
        0 0 12px rgba(124, 58, 237, 0.45),
        0 0 26px rgba(6, 182, 212, 0.22),
        0 0 42px rgba(244, 114, 182, 0.16);
    }
    20%,
    55% {
      opacity: 0.88;
      text-shadow:
        0 0 16px rgba(124, 58, 237, 0.75),
        0 0 36px rgba(6, 182, 212, 0.34),
        0 0 56px rgba(244, 114, 182, 0.22);
    }
  }

  @keyframes tagSweep {
    0%,
    100% {
      transform: translateX(-135%);
      opacity: 0;
    }
    18% {
      opacity: 0.9;
    }
    42% {
      transform: translateX(140%);
      opacity: 0;
    }
  }

  @keyframes avatarFloat {
    0%,
    100% {
      transform: rotate(4deg) translateY(0);
    }
    50% {
      transform: rotate(2deg) translateY(-12px);
    }
  }

  @keyframes orbitGlow {
    0% {
      transform: rotate(0deg) scale(1);
      opacity: 0.4;
    }
    50% {
      transform: rotate(180deg) scale(1.04);
      opacity: 0.85;
    }
    100% {
      transform: rotate(360deg) scale(1);
      opacity: 0.4;
    }
  }

  @keyframes glowPulse {
    0%,
    100% {
      transform: scale(0.94);
      opacity: 0.55;
    }
    50% {
      transform: scale(1.1);
      opacity: 0.9;
    }
  }

  @keyframes floatCardA {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-10px, -12px, 0);
    }
  }

