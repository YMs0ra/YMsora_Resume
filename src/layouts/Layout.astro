---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'YMsora Resume',
  description = 'A dazzling markdown-powered resume website.',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #070816;
        --bg-soft: rgba(20, 24, 48, 0.72);
        --card: rgba(13, 18, 38, 0.92);
        --card-strong: rgba(16, 20, 40, 0.96);
        --line: rgba(255, 255, 255, 0.12);
        --text: #f5f7ff;
        --muted: #a8b1d1;
        --accent: #7c3aed;
        --accent-2: #06b6d4;
        --accent-3: #f472b6;
        --shadow: 0 20px 50px rgba(0, 0, 0, 0.34);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          linear-gradient(180deg, rgba(124, 58, 237, 0.08), transparent 24%),
          linear-gradient(135deg, #05060f 0%, #090b1c 48%, #120f28 100%);
        color: var(--text);
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        pointer-events: none;
        z-index: 0;
      }

      body::before {
        inset: 18px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 30px;
        box-shadow:
          inset 0 0 0 1px rgba(6, 182, 212, 0.05),
          0 0 0 1px rgba(124, 58, 237, 0.05);
      }

      body::after {
        left: 18px;
        right: 18px;
        top: 18px;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(6, 182, 212, 0.45), rgba(124, 58, 237, 0.35), transparent);
        opacity: 0.75;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .page-shell {
        position: relative;
        z-index: 1;
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 40px 0 72px;
      }

      .page-shell::before,
      .page-shell::after {
        content: "";
        position: fixed;
        pointer-events: none;
        z-index: -1;
      }

      .page-shell::before {
        inset: 32px;
        border-radius: 24px;
        background:
          linear-gradient(90deg, transparent 0%, rgba(6, 182, 212, 0.1) 16%, transparent 18%),
          linear-gradient(180deg, transparent 0%, rgba(124, 58, 237, 0.08) 18%, transparent 22%);
        background-size: 100% 100%, 100% 100%;
        opacity: 0.5;
      }

      .page-shell::after {
        inset: 24px;
        border-radius: 28px;
        border: 1px solid rgba(255, 255, 255, 0.04);
      }

      .hud-corner {
        position: fixed;
        width: 84px;
        height: 84px;
        pointer-events: none;
        z-index: 0;
        opacity: 0.75;
      }

      .hud-corner::before,
      .hud-corner::after {
        content: "";
        position: absolute;
        background: linear-gradient(90deg, rgba(6, 182, 212, 0.75), rgba(124, 58, 237, 0.4));
      }

      .hud-corner::before {
        width: 52px;
        height: 2px;
      }

      .hud-corner::after {
        width: 2px;
        height: 52px;
      }

      .hud-tl { top: 24px; left: 24px; }
      .hud-tr { top: 24px; right: 24px; transform: scaleX(-1); }
      .hud-bl { bottom: 24px; left: 24px; transform: scaleY(-1); }
      .hud-br { bottom: 24px; right: 24px; transform: scale(-1); }
    </style>
  </head>
  <body>
    <div class="hud-corner hud-tl" aria-hidden="true"></div>
    <div class="hud-corner hud-tr" aria-hidden="true"></div>
    <div class="hud-corner hud-bl" aria-hidden="true"></div>
    <div class="hud-corner hud-br" aria-hidden="true"></div>
    <div class="page-shell">
      <slot />
    </div>
  </body>
</html>
